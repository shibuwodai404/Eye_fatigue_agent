# ============================================================
# Visual Fatigue Agent —— 环境配置示例
# 复制本文件为 .env 并按需修改
# ============================================================

# ---- Ollama ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:35b-a3b
OLLAMA_VL_MODEL=qwen3-vl:8b
# 诊断 self-consistency 用的三个 temperature
DIAGNOSIS_TEMPERATURES=0.3,0.5,0.7
# 通用兜底 temperature
DEFAULT_TEMPERATURE=0.2
# 请求超时（秒），35B MoE 首调较慢
LLM_TIMEOUT_SECONDS=180

# ---- Vision FastAPI 服务 ----
VISION_API_BASE_URL=http://localhost:8765
VISION_API_TIMEOUT_SECONDS=600

# ---- 病例库 ----
# JSONL = 第一版无需 PG 的 fallback
# POSTGRES = 切到 PG + pgvector
CASE_DB_BACKEND=JSONL
CASE_DB_JSONL_PATH=./logs/case_library.jsonl
# 仅在 BACKEND=POSTGRES 时生效
POSTGRES_DSN=postgresql://eye_agent:eye_agent@localhost:5432/eye_agent
POSTGRES_VECTOR_DIM=1024

# ---- Embedding（BGE-M3，本地） ----
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cuda
EMBEDDING_DIM=1024

# ---- RAG 知识库 ----
RAG_DOCS_DIR=./scripts/knowledge_docs
RAG_INDEX_DIR=./logs/rag_index
RAG_TOP_K=4

# ---- 日志 ----
LOG_DIR=./logs
LLM_TRACE_DIR=./logs/llm_traces
LOG_LEVEL=INFO

# ---- 消融实验开关（实验时打开对应 disable_*） ----
DISABLE_RAG=false
DISABLE_CONSISTENCY=false
DISABLE_CASE_LIBRARY=false
DISABLE_SIMILAR_CASES=false
